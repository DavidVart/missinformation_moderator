# ── Core AI ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# ── Supabase (Postgres) ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Legacy alias used by services — points to same Supabase connection
POSTGRES_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Upstash (Redis) ──
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=
# TCP connection for Redis Streams (required by backend services)
REDIS_URL=rediss://default:<token>@<id>.upstash.io:6379

# ── Clerk (auth) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── PostHog (product analytics) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (error tracking) ──
SENTRY_DSN=https://<key>@o<org>.ingest.us.sentry.io/<project>
SENTRY_AUTH_TOKEN=

# ── Pinecone (vector DB) ──
PINECONE_API_KEY=
PINECONE_INDEX=realtalk
PINECONE_ENVIRONMENT=us-east-1

# ── Whisper Worker ──
WHISPER_WORKER_URL=http://whisper-worker:8000
WHISPER_MODEL=base
WHISPER_LANGUAGE=
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0

# ── App Config ──
INTERVENTION_CONFIDENCE_THRESHOLD=0.75
SESSION_TTL_SECONDS=3600
CORS_ORIGIN=*
LOG_LEVEL=info
